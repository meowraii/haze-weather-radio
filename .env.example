HAZE_MEDIA_WEBRTC_UDP_PORT_MIN= # Optional override for the configured UDP port minimum
HAZE_MEDIA_WEBRTC_UDP_PORT_MAX= # Optional override for the configured UDP port maximum
HAZE_WEB_DISABLE_HTTP2=false # Set true when a reverse proxy needs HTTP/1.1 for long-running audio streams
HAZE_MEDIA_LOUDNESS_ENABLED=true
HAZE_MEDIA_GAIN_DB=3
