HAZE_PUBLIC_BASE_URL=
# Set this to the LAN IP receivers should use in WebRTC ICE host candidates.
# The daemon reads this at startup, so restart haze after changing it.
HAZE_MEDIA_WEBRTC_HOST=172.16.1.30
HAZE_WEBRTC_DEFAULT_CODEC=opus # opus, g722, pcmu, or pcma; Opus is preferred when the native encoder is bundled
HAZE_MEDIA_LOUDNESS_ENABLED=true
HAZE_MEDIA_GAIN_DB=3
HAZE_MEDIA_COMPRESSOR_THRESHOLD_DBFS=-18
HAZE_MEDIA_COMPRESSOR_RATIO=3
HAZE_MEDIA_COMPRESSOR_MAKEUP_DB=1.5
HAZE_MEDIA_LIMITER_CEILING=0.98
SITE_NAME=Haze Weather Radio
MIST_RTMP_SSPWXR01=
HAZE_DISCORD_WEBHOOK_SK0001=
HAZE_DISCORD_WEBHOOK_CWXR_SK02=
HAZE_DISCORD_WEBHOOK_CWXR_AB01=
HAZE_DISCORD_WEBHOOK_CWXR_MB01=
DASDEC_PASSWORD=
DASDEC_USER=
