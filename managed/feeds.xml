    </output>

  </feed>






  <feed id="naads-catchall" callsign="SSPWXR" enabled="false" timezone="America/Regina">

    <playout routine="false" same="true"/>

    <alerts>
      <cap_cp enabled="true">
        <!-- use_feed_locations="false": accept all CAP-CP alerts regardless of location -->
        <filter use_feed_locations="false"/>
      </cap_cp>
      <nws_cap enabled="false"/>
    </alerts>

    <description>
      <lang code="en-CA" text="EMERGENCY ALERT CHANNEL FOR METEOCHANNEL."/>
    </description>

    <locations>
      <coverage>
        <!-- all supported keys: region, SAME, province/state, zone, county
        only SAME, province/state, and counties support alert only coverage, so derive_forecast is ignored on those keys.
        -->

        <province abbr="SK" /> <!-- automatically matches all 06* SAME codes found in the FORECAST_LOCATIONS.csv file. or NWS_ZONE_COUNTY_CORRELATION if state-->
        <province abbr="MB" />
        <province abbr="AB" />
        <state abbr="ND" />
        <state abbr="MT" />
      </coverage>
    </locations>

    <output>

      <stream enabled="true">
        <type>icecast</type>
        <host>icecast.almora.tv</host>
        <port>8443</port>
        <username>source</username>
        <password>aluser</password>
        <ssl>false</ssl>
        <format>vp9</format>
        <bitrate_kbps>32</bitrate_kbps>
      </stream>

      <udp enabled="true">
        <ip>127.0.0.1</ip>
        <port>8898</port>
        <format>mpegts</format>
        <bitrate_kbps>64</bitrate_kbps>
        <vrate_kbps>4000</vrate_kbps>
        <vcodec>h264_amf</vcodec>
        <acodec>ac3</acodec>
      </udp>

      <rtp enabled="false">
        <ip>127.0.0.1</ip>
        <port>8899</port>
        <format>rtp_mpegts</format>
        <bitrate_kbps>96</bitrate_kbps>
        <vrate_kbps>4000</vrate_kbps>
        <vcodec>h264_amf</vcodec>
        <acodec>ac3</acodec>
      </rtp>

      <framebuffer enabled="false">
        <path>/dev/fb0</path>
      </framebuffer>

      <dri enabled="false">
        <path>/dev/dri/card0</path>
      </dri>

      <v4l2 enabled="false">
        <device>/dev/video0</device>
      </v4l2>

      <audio_device enabled="false"/>
      <PiFmAdv enabled="false"/>

    </output>

  </feed>

</feeds>
