          </blocklist>
        </filter>
      </cap_cp>
      <nws_cap enabled="false"/>
    </alerts>

    <languages>
      <lang code="en-CA" interval="0"/>
    </languages>

    <description>
      <lang code="en-CA"
            text="This broadcast provides service to the Lake Diefenbaker area, including the communities of Elbow, Outlook, and Lucky Lake."
            suffix="This service is not affiliated with Environment Canada"/>
    </description>

    <locations>
      <coverage>
        <region id="065500" source="eccc" derive_forecast="sk-18">
          <subregion id="065524"/>
        </region>
        <region id="065500" source="eccc" derive_forecast="sk-37">
          <subregion id="065522"/>
          <subregion id="06552*"/>
        </region>
        <region id="062200" source="eccc" derive_forecast="sk-24">
          <subregion id="065526"/>
          <subregion id="06221*"/>
        </region>
      </coverage>

      <observationLocations>
        <location id="sk-18" source="eccc"/>
        <location id="sk-37" source="eccc"/>
        <location id="sk-14" source="eccc"/>
      </observationLocations>
    </locations>

    <output>

      <stream enabled="true">
        <type>icecast</type>
        <host>icecast.almora.tv</host>
        <port>8443</port>
        <username>source</username>
        <password>aluser</password>
