<?xml version="1.0" encoding="UTF-8"?>
<!-- custom output config for Canada Weather Radio Service -->
<outputs>
  <feed id="cwxr-*">
    <webrtc enabled="true"/>

    <icecast enabled="true">
      <host>${HAZE_ICECAST_HOST}</host>
      <port>${HAZE_ICECAST_PORT}</port>
      <username>${HAZE_ICECAST_USERNAME}</username>
      <password>${HAZE_ICECAST_SOURCE_PASSWORD}</password>
      <mount></mount>
      <ssl>false</ssl>
      <format>opus</format>
      <bitrate_kbps>32</bitrate_kbps>
      <acodec>libopus</acodec>
    </icecast>

    <udp enabled="false"/>
    <rtp enabled="false"/>
    <rtmp enabled="false"/>
    <srt enabled="false"/>
    <rtsp enabled="false"/>
    <audio_device enabled="false"/>
  </feed>
</outputs>
