<?xml version="1.0" encoding="UTF-8"?>
<!-- custom output config for Canada Weather Radio Service -->
<outputs>
  <feed id="cwxr-sk01">
    <webrtc enabled="true"/>

    <stream enabled="true">
      <type>icecast</type>
      <host>${HAZE_ICECAST_HOST}</host>
      <port>${HAZE_ICECAST_PORT}</port>
      <username>${HAZE_ICECAST_USERNAME}</username>
      <password>${HAZE_ICECAST_SOURCE_PASSWORD}</password>
      <mount>/cwxr-sk01</mount>
      <ssl>false</ssl>
      <format>opus</format>
      <bitrate_kbps>64</bitrate_kbps>
      <acodec>libopus</acodec>
    </stream>

    <udp enabled="false">
      <ip>172.16.1.37</ip>
      <port>8898</port>
      <format>mpegts</format>
      <bitrate_kbps>32</bitrate_kbps>
      <acodec>libopus</acodec>
    </udp>

    <rtp enabled="false">
      <ip>172.16.1.37</ip>
      <port>8899</port>
      <format>rtp_mpegts</format>
      <bitrate_kbps>32</bitrate_kbps>
      <acodec>libopus</acodec>
    </rtp>

    <rtmp enabled="false">
      <url>rtmp://localhost/live/cwxr-sk01</url>
      <format>flv</format>
      <bitrate_kbps>32</bitrate_kbps>
      <acodec>aac</acodec>
    </rtmp>

    <srt enabled="false">
      <url>srt://localhost:12345</url>
      <format>mpegts</format>
      <bitrate_kbps>32</bitrate_kbps>
      <acodec>aac</acodec>
    </srt>

    <rtsp enabled="false">
      <url>rtsp://localhost:8554/cwxr-sk01</url>
      <format>rtsp</format>
      <bitrate_kbps>32</bitrate_kbps>
      <acodec>aac</acodec>
    </rtsp>

    <audio_device enabled="true"/>
  </feed>

